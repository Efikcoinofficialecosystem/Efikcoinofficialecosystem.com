<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ECE ETERNAL | Legacy Security Gate</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/5.7.2/ethers.umd.min.js"></script>
    <style>
        :root { --gold: #f2bc1b; --dark: #010409; }
        body { background: var(--dark); color: #f0f6fc; font-family: system-ui, sans-serif; }
        .gate-overlay { position: fixed; inset: 0; background: var(--dark); z-index: 9999; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(20px); }
        .glass-card { background: #0d1117; border: 1px solid #30363d; border-radius: 32px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5); }
        .gold-glow { color: var(--gold); text-shadow: 0 0 15px rgba(242, 188, 27, 0.3); }
        .btn-gold { background: var(--gold); color: #000; font-weight: 900; border-radius: 14px; transition: 0.3s; cursor: pointer; }
        .input-dark { background: rgba(255,255,255,0.03); border: 1px solid #30363d; border-radius: 12px; padding: 12px; outline: none; width: 100%; color: white; }
        .hidden-ui { display: none; }
    </style>
</head>
<body>

    <div id="securityGate" class="gate-overlay p-6">
        <div class="glass-card max-w-md w-full p-10 text-center space-y-8">
            <img src="https://raw.githubusercontent.com/Efikcoinofficialecosystem/efikcoin-eternal/main/1772019882787.png" class="w-24 h-24 mx-auto rounded-full border-2 border-[#f2bc1b] mb-4">
            <div>
                <h2 class="text-2xl font-black gold-glow uppercase tracking-tighter">Identity Protection</h2>
                <p class="text-[10px] text-gray-500 font-bold uppercase mt-2 tracking-widest">Sovereign Level 1 Access Required</p>
            </div>

            <div id="regForm" class="space-y-4 text-left">
                <div>
                    <label class="text-[9px] font-black text-gray-600 uppercase ml-2">Legacy Name</label>
                    <input id="regName" type="text" placeholder="Full Legal Name" class="input-dark mt-1">
                </div>
                <div>
                    <label class="text-[9px] font-black text-gray-600 uppercase ml-2">Secure Email</label>
                    <input id="regEmail" type="email" placeholder="official@example.com" class="input-dark mt-1">
                </div>
                <button onclick="startVerification()" id="gateBtn" class="btn-gold w-full py-4 uppercase text-xs tracking-widest mt-4">Sync Wallet & Verify</button>
            </div>

            <p class="text-[9px] text-gray-600 leading-relaxed italic">"By entering, you agree to the ECE Legacy Code of Conduct and Anti-Fraud Protection protocols."</p>
        </div>
    </div>

    <div id="mainSurface" class="hidden-ui p-4 md:p-10 opacity-0 transition-opacity duration-1000">
        <nav class="max-w-6xl mx-auto flex justify-between items-center mb-12">
            <div class="flex items-center gap-4">
                <img src="https://raw.githubusercontent.com/Efikcoinofficialecosystem/efikcoin-eternal/main/1772019882787.png" class="w-12 h-12 rounded-full border border-[#f2bc1b]">
                <h1 class="text-xl font-black gold-glow">ECE ETERNAL</h1>
            </div>
            <div class="bg-[#161b22] border border-[#30363d] px-6 py-2 rounded-full text-[10px] font-mono text-green-400">
                SECURE: <span id="displayAddr">0x...</span>
            </div>
        </nav>

        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-10">
            <div class="glass-card p-8 space-y-6">
                <h3 class="text-xs font-black text-gray-500 uppercase">Legacy Utility Terminal</h3>
                <div style="height: 400px;">
                    <iframe width="100%" height="100%" src="https://www.geckoterminal.com/bsc/pools/0x7fabe0647d6e81075727a858e65860955e5170b6?embed=1&info=0&swaps=1"></iframe>
                </div>
            </div>
            
            <div class="glass-card p-8 flex flex-col justify-center text-center space-y-6">
                <div class="bg-green-500/10 p-6 rounded-2xl border border-green-500/20">
                    <p class="text-green-500 text-xs font-black uppercase">Identity Verified</p>
                    <p id="welcomeMsg" class="text-white font-bold mt-2">Welcome, Sovereign User</p>
                </div>
                <p class="text-[11px] text-gray-500">Your interaction with the ECE Blockchain is now protected under your verified Legacy Profile.</p>
                <button class="btn-gold py-5 text-xs uppercase tracking-widest shadow-xl">Launch Trade Engine</button>
            </div>
        </div>
    </div>

    <script>
        let provider, signer;

        async function startVerification() {
            const name = document.getElementById('regName').value;
            const email = document.getElementById('regEmail').value;

            if(!name || !email) {
                alert("Please enter your Legacy Name and Email for security protection.");
                return;
            }

            if (!window.ethereum) {
                alert("Blockchain Wallet Not Detected. Please use Trust Wallet or MetaMask.");
                return;
            }

            try {
                // Change button state
                const btn = document.getElementById('gateBtn');
                btn.innerText = "VERIFYING ON-CHAIN...";
                btn.classList.add('animate-pulse');

                // Connect Wallet
                provider = new ethers.providers.Web3Provider(window.ethereum);
                await provider.send("eth_requestAccounts", []);
                signer = provider.getSigner();
                const addr = await signer.getAddress();

                // Save to "Legacy Storage" (Browser local storage for now)
                const userData = { name, email, wallet: addr, timestamp: Date.now() };
                localStorage.setItem('ece_legacy_user', JSON.stringify(userData));

                // SUCCESS: Transition to Website Surface
                unlockWebsite(name, addr);

            } catch (err) {
                alert("Verification Failed: User Denied Signature.");
                btn.innerText = "Sync Wallet & Verify";
                btn.classList.remove('animate-pulse');
            }
        }

        function unlockWebsite(name, addr) {
            const gate = document.getElementById('securityGate');
            const surface = document.getElementById('mainSurface');
            
            // Fade out gate, Fade in website
            gate.style.transition = "opacity 0.5s ease";
            gate.style.opacity = "0";
            
            setTimeout(() => {
                gate.style.display = "none";
                surface.classList.remove('hidden-ui');
                setTimeout(() => {
                    surface.style.opacity = "1";
                    document.getElementById('displayAddr').innerText = addr.slice(0,6) + "..." + addr.slice(-4);
                    document.getElementById('welcomeMsg').innerText = "Welcome, " + name;
                }, 100);
            }, 500);
        }

        // AUTO-LOGIN if already registered
        window.onload = () => {
            const saved = localStorage.getItem('ece_legacy_user');
            if(saved) {
                const data = JSON.parse(saved);
                // Optional: You could force a wallet reconnect here, 
                // but for speed, we show the surface.
                unlockWebsite(data.name, data.wallet);
            }
        };
    </script>
</body>
</html>
